# Copy this file to .env and fill in the required values.

# -- Required --
# LLM provider API key used by the app's LLM adapter
GROQ_API_KEY=

# Model identifier (provider-specific). Default set in app/config.py
GROQ_MODEL=openai/gpt-oss-120b

# -- Optional / runtime --
# API prefix (kept in config, override if needed)
API_V1_PREFIX=/api/v1

# Frontend allowed origin (for CORS during development)
FRONTEND_ORIGIN=http://localhost:5173

# History backend: `memory` or `file`
HISTORY_BACKEND=memory
HISTORY_DIR=./history

# Environment flags
ENVIRONMENT=development
DEBUG=false

# Logging level (optional override for logging_config)
LOG_LEVEL=INFO
